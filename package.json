{
  "name": "js-e2e-express-server",
  "version": "1.0.0",
  "description": "JavaScript server written with Express.js",
  "author": "",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  },
  "scripts": {
    "sonar": "sonar-scanner",
    "build": "npm run lint",
    "start": "node src/index.js",
    "start:dev": "npm run lint && nodemon --exec node src/index.js --unhandled-rejections=warn",
    "test": "jest --detectOpenHandles --forceExit --coverage",
    "lint": "eslint src/**/*.js --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azure-samples/js-e2e-express-server.git"
  },
  "keywords": [],
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/azure-samples/js-e2e-express-server/issues"
  },
  "homepage": "https://github.com/azure-samples/js-e2e-express-server#readme",
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "sonar-scanner": "^3.1.0",
    "supertest": "^7.0.0"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "prom-client": "^15.1.3",
    "serve-favicon": "^2.5.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "reports",
          "outputName": "junit.xml"
        }
      ]
    ]
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  }
}
